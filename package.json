    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.2",
    "homebridge": "^2.1.0",
    "typescript": "^5.7.2"
  }
